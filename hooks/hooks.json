{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/setup/setup.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-lifecycle.sh",
            "timeout": 10,
            "statusMessage": "LOCI: Initializing execution-aware monitoring..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-lifecycle.sh",
            "timeout": 15,
            "statusMessage": "LOCI: Generating session summary..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture-action.sh",
            "timeout": 5,
            "statusMessage": "LOCI: Analyzing command..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture-action.sh",
            "timeout": 5,
            "statusMessage": "LOCI: Checking code modification..."
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture-action.sh",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "mcp__loci-plugin__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture-action.sh",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture-action.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "mcp__loci-plugin__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture-action.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}