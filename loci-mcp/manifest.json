{
  "name": "loci-mcp",
  "version": "1.1.0",
  "description": "LOCI Execution-Aware Plugin for C++ — captures compilation, binary artifacts, and source modifications, streaming context to AuroraLabs LOCI MCP server for binary-level performance, timing, regression, and power analysis",
  "author": "AuroraLabs",
  "homepage": "https://www.auroralabs.com/",
  "hooks": "hooks.json",
  "config": "config/loci.json",
  "mcpServer": {
    "name": "loci-mcp",
    "url": "https://dev.mcp.loci-dev.net/mcp",
    "transport": "sse"
  },
  "environment": "cpp",
  "requires": {
    "claude_code": ">=1.0.0",
    "tools": ["jq", "g++|clang++"]
  },
  "capabilities": [
    "cpp_action_capture",
    "binary_artifact_tracking",
    "compilation_monitoring",
    "execution_aware_analysis",
    "performance_warnings",
    "regression_detection",
    "assembly_tracking",
    "loci_mcp_integration"
  ]
}
